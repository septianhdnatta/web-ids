{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/contributor/profile",
      "dest": "/contributor/profile.html"
    },
    {
      "src": "/contributor/leaderboard",
      "dest": "/contributor/leaderboard.html"
    },
    {
      "src": "/login",
      "dest": "/login/login.html"
    },
    {
      "src": "/register",
      "dest": "/register/register.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard/dashboard.html"
    },
    {
      "src": "/dashboard-admin",
      "dest": "/dashboard/dashboard-admin.html"
    },
    {
      "src": "/ID",
      "dest": "/ID/id.html"
    },
    {
      "src": "/payment",
      "dest": "/payment/payment.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
